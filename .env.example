# -----------------------------------------------------------------------
# Argo MCP Server Configuration
# Copy to .env and fill in your values.
# NEVER commit your actual .env file.
# -----------------------------------------------------------------------

# Base URL for the Argo WebAPI (via Oathkeeper)
ARGO_API_BASE=https://api.argo.games/api/v1

# Hosted HTTP mode overrides
# Public base URL of this MCP service. Used in OAuth discovery metadata.
# MCP_BASE_URL=https://mcp.argo.games

# OAuth issuer / Hydra public host used by hosted-mode discovery endpoints.
# ARGO_OAUTH_BASE=https://oauth.argo.games

# WebAPI base used by the DCR proxy in hosted mode.
# WEBAPI_BASE=https://api.argo.games

# ChatGPT domain verification token served at:
#   /.well-known/openai-apps-challenge
# OPENAI_CHALLENGE_TOKEN=

# OAuth2 access token obtained via the Argo Hydra consent flow.
# The token must have campaign.read scope (and campaign.write for write tools).
# Obtain via: https://oauth.argo.games/oauth2/auth?client_id=argo-mcp&...
OAUTH_TOKEN=

# Optional: override the transport (stdio | sse). Defaults to stdio.
# MCP_TRANSPORT=stdio
