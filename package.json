{
  "name": "argo-mcp",
  "version": "1.0.2",
  "description": "MCP server for Argo RPG Platform — connects AI assistants to campaign data via OAuth2",
  "mcpName": "io.github.Argo-RPG-Platform/argo-mcp",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "argo-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node scripts/postbuild.mjs",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Argo-RPG-Platform/MCP.git"
  },
  "homepage": "https://github.com/Argo-RPG-Platform/MCP#readme",
  "bugs": {
    "url": "https://github.com/Argo-RPG-Platform/MCP/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "argo",
    "vtt",
    "ttrpg",
    "oauth"
  ],
  "author": "Argo RPG Platform",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "jose": "^6.2.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
